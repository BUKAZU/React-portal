{
  "name": "bukazu-portal-react",
  "version": "3.9.0",
  "engines": {
    "node": ">=22"
  },
  "description": "A package for loading the calendar and search module from bukazu loading into a react app.",
  "repository": "https://github.com/BUKAZU/React-portal",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build": "vite build",
    "build:analyze": "cross-env ANALYZE=true vite build",
    "dev": "vite"
  },
  "author": "Bob van Oorschot",
  "license": "MIT",
  "type": "module",
  "peerDependencies": {
    "react": "^16.14.0 || ^17.0.2 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.14.0 || ^17.0.2 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.15.0",
    "@babel/plugin-proposal-class-properties": "^7.13.0",
    "@babel/preset-env": "^7.15.0",
    "@babel/preset-react": "^7.14.5",
    "@babel/preset-typescript": "^7.18.6",
    "@jest/globals": "^30.3.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.4.0",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.10",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.13",
    "chalk": "5.6.2",
    "cross-env": "^10.1.0",
    "eslint": "^8.49.0",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.24.0",
    "fs-extra": "11.3.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.3.0",
    "path": "^0.12.7",
    "path-browserify": "^1.0.0",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^11.2.0",
    "prettier": "^3.0.3",
    "process": "^0.11.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resolve": "1.22.12",
    "rollup-plugin-visualizer": "^7.0.1",
    "terser": "^5.46.0",
    "ts-jest": "^29.0.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.3",
    "whatwg-fetch": "3.6.20"
  },
  "dependencies": {
    "@apollo/client": "^4.1.9",
    "@sentry/browser": "^10.45.0",
    "date-fns": "^4.1.0",
    "formik": "^2.2.9",
    "graphql": "^16.11.0",
    "graphql-request": "^7.4.0"
  },
  "main": "./build/portal.umd.js",
  "module": "./build/portal.es.js",
  "exports": {
    ".": {
      "import": "./build/portal.es.js",
      "require": "./build/portal.umd.js"
    },
    "./index.css": "./build/index.css",
    "./build/index.css": "./build/index.css"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:react/recommended",
      "plugin:jsx-a11y/recommended"
    ],
    "parser": "babel-eslint",
    "env": {
      "browser": true,
      "node": true
    },
    "rules": {
      "strict": 0,
      "no-console": "warn",
      "quotes": [
        "warn",
        "single"
      ],
      "prettier/prettier": "warn"
    },
    "plugins": [
      "prettier",
      "jsx-a11y"
    ]
  }
}
